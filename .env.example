# Server
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Security
ADMIN_TOKEN=replace_with_a_long_random_secret

# Storage files (persist these paths in your hosting volume)
USERS_STORE_FILE=/var/lib/misrsteel/users.json
SITE_CONFIG_FILE=/var/lib/misrsteel/site-config.json

# AI (optional)
STABILITY_API_KEY=
OPENAI_API_KEY=
MAX_PROMPT_LENGTH=1200
